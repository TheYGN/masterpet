# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude / local dev artifacts
.claude/*
!.claude/skills/
.claude/settings.local.json
.playwright-mcp/
/*.png

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local

# office temp lock files (e.g. ~$file.xlsx — created while a file is open)
~$*

# local workflow helpers (one-off scripts, not source)
.scratch/

# excalidraw safety backups (dated copies kept locally, not in history)
pet_platform_tree.excalidraw.backup-*

.vercel
.env*.local
